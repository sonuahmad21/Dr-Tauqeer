{
  "name": "shipla",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,css,mjs,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,css,mjs,yml,yaml}\"",
    "typecheck": "turbo run typecheck",
    "db:generate": "turbo run db:generate --filter=@shipla/database",
    "db:push": "turbo run db:push --filter=@shipla/database",
    "db:studio": "pnpm --filter @shipla/database studio",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs,json,md,css,yml,yaml}": [
      "prettier --write"
    ]
  }
}
